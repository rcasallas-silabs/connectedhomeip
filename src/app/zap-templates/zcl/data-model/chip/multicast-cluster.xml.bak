<configurator>
  <domain name="General"/>

  <enum name="SampleEnum" type="enum8">
    <cluster code="0x0064"/>
    <item name="Off" value="0x00"/>
    <item name="On" value="0x01"/>
  </enum>

  <bitmap name="SampleBitmap" type="bitmap8">
    <cluster code="0x0064"/>
    <field name="Enabled" mask="0x01"/>
  </bitmap>

  <struct name="MulticastTargetStruct" isFabricScoped="true">
    <cluster code="0x0064"/>
    <item fieldId="1" name="TargetId" type="group_id"/>
    <item fieldId="2" name="Endpoints" type="endpoint_no" array="true"/>
  </struct>

  <struct name="MulticastAddStruct" isFabricScoped="true">
    <cluster code="0x0064"/>
    <item fieldId="1" name="TargetId" type="group_id"/>
    <item fieldId="2" name="Endpoint" type="endpoint_no" />
    <item fieldId="3" name="Key" type="octet_string" length="16"/>
  </struct>

  <cluster>
    <name>Multicast</name>
    <domain>General</domain>
    <code>0x0064</code>
    <define>MULTICAST_CLUSTER</define>
    <description>Multicast Messages.</description>
    <globalAttribute side="either" code="0xFFFD" value="6"/>

    <features>
      <feature bit="0" code="X" name="Xtras" summary="Support extras.">
        <optionalConform>
          <notTerm>
            <feature name="OFFONLY"/>
          </notTerm>
        </optionalConform>
      </feature>
    </features>
    
    <attribute side="server" code="0x0000" name="Targets" define="MULTICAST_TARGETS" type="array" length="254" entryType="MulticastTargetStruct">
      <mandatoryConform/>
    </attribute>

    <command source="client" code="0x00" name="AddTarget" isFabricScoped="true" optional="false" cli="zcl Multicast AddTarget">
      <description>
        Adds a target
      </description>
      <arg name="Target" type="MulticastAddStruct"/>
      <access op="invoke" privilege="administer"/>
      <mandatoryConform/>
    </command>
  </cluster>

</configurator>
